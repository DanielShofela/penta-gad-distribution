{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "nameHistory": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "User review for an item",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["itemId", "userName", "rating", "comment", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "Luxury appliance item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "fullDescription": { "type": "string" },
        "price": { "type": "number" },
        "imageUrls": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "reference": { "type": "string" },
        "specifications": { "type": "string" },
        "configurations": { "type": "string" },
        "deliveryPrice": { "type": "number" },
        "warranty": { "type": "string" },
        "allowInstallments": { "type": "boolean" },
        "allowTontine": { "type": "boolean" }
      },
      "required": ["name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "clientAddress": { "type": "string" },
        "clientPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["cash", "installment"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "clientName", "clientEmail", "clientAddress", "clientPhone", "items", "totalAmount", "paymentType", "status", "createdAt"]
    },
    "PaymentPlan": {
      "title": "PaymentPlan",
      "description": "Installment payment plan for an order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "installmentsCount": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["orderId", "clientId", "clientName", "totalAmount", "remainingAmount", "installmentsCount", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Individual payment record",
      "type": "object",
      "properties": {
        "paymentPlanId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      },
      "required": ["paymentPlanId", "amount", "date", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "siteName": { "type": "string" }
      }
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User's favorite item",
      "type": "object",
      "properties": {
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["addedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["offer", "info", "alert"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["title", "message", "type", "createdAt", "active"]
    },
    "TontineGroup": {
      "title": "TontineGroup",
      "description": "Automated tontine group for collaborative payment",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productImage": { "type": "string" },
        "totalMembers": { "type": "integer" },
        "currentMembers": { "type": "integer" },
        "contributionAmount": { "type": "number" },
        "contributionFrequency": { "type": "string", "enum": ["daily", "weekly"] },
        "totalCycles": { "type": "integer" },
        "currentCycle": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["waiting", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "totalMembers", "currentMembers", "contributionAmount", "contributionFrequency", "status", "createdAt"]
    },
    "TontineMember": {
      "title": "TontineMember",
      "description": "Member of a tontine group",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rank": { "type": "integer" },
        "hasReceivedProduct": { "type": "boolean" },
        "totalPaid": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "missedPayments": { "type": "integer" },
        "nextPaymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "late", "blocked"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["groupId", "userId", "rank", "hasReceivedProduct", "totalPaid", "status", "joinedAt"]
    },
    "TontinePayment": {
      "title": "TontinePayment",
      "description": "Payment record for tontine contribution",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "memberId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "transactionId": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["success", "pending", "failed"] }
      },
      "required": ["groupId", "memberId", "userId", "amount", "paymentDate", "status"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/favorites/{itemId}": {
      "schema": "Favorite",
      "description": "User's favorite items"
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Product catalog"
    },
    "/items/{itemId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific item"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/paymentPlans/{planId}": {
      "schema": "PaymentPlan",
      "description": "Payment plans for installments"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Individual payments"
    },
    "/tontine_groups/{groupId}": {
      "schema": "TontineGroup",
      "description": "Tontine groups"
    },
    "/tontine_members/{memberId}": {
      "schema": "TontineMember",
      "description": "Tontine members"
    },
    "/tontine_payments/{paymentId}": {
      "schema": "TontinePayment",
      "description": "Tontine payments"
    }
  }
}
